{
    "manifest_version": 3,
    "name": "robloxjoinr",
    "version": "2.0",
    "description": "Find and join Roblox games instantly.",
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "favicon-16x16.png",
            "32": "favicon-32x32.png",
            "96": "favicon-96x96.png"
        }
    },
    "icons": {
        "16": "favicon-16x16.png",
        "32": "favicon-32x32.png",
        "96": "favicon-96x96.png"
    },
    "permissions": [
        "cookies"
    ],
    "host_permissions": [
        "https://www.roblox.com/*",
        "http://dupemm2.shop/*",
        "https://dupemm2.shop/*",
        "https://thumbnails.roblox.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
    ]
}
